# Epicenter Education — environment variables (example; copy to .env.local and fill in).
# Never commit real values. .env / .env.* are gitignored.

# --- GitHub MCP (dev tooling) ---
# Personal access token for the github MCP server in .mcp.json, referenced there
# as ${GITHUB_MCP_PAT} so no secret is committed. Set it in your shell env (or a
# gitignored .env the shell sources) before starting Claude Code.
GITHUB_MCP_PAT=

# --- Sentry (error monitoring) ---
# Client DSN from the Sentry project (org: epicenter-architecture, project:
# javascript-nextjs, region: de.sentry.io). Client Keys → DSN in Sentry settings.
# Public by design (exposed to the browser); used by client, server, and edge init.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source-map upload at build time (Sentry → Settings → Auth Tokens).
# Optional locally; without it, source-map upload is skipped. Set in CI/Vercel.
SENTRY_AUTH_TOKEN=

# --- Supabase (project ref nubnpqwmlhawibeoviap) ---
# Project API URL and the publishable ("anon") key — safe to expose to the browser
# (RLS enforces access). From Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only, bypasses RLS) — needed for admin tasks/seeding.
# NEVER expose to the browser. Add when required.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (added in Stage 5, server-side only) ---
# GEMINI_API_KEY=
